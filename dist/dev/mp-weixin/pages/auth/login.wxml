<view class="page login-page"><view class="section login-card"><view class="login-card-header"><view class="card-title">手机号快捷登录</view><view class="card-subtitle">新手机号首次登录将自动为您注册账号</view></view><view class="field"><text class="label">手机号码</text><view class="input-wrapper"><text class="phone-prefix">+86</text><input class="input phone-input" type="number" maxlength="11" placeholder="请输入您的手机号" placeholder-class="placeholder-style" value="{{a}}" bindinput="{{b}}"/></view></view><view class="field"><text class="label">验证码</text><view class="input-wrapper code-wrapper"><input class="input code-input" type="number" maxlength="6" placeholder="请输入验证码" placeholder-class="placeholder-style" value="{{c}}" bindinput="{{d}}"/><button class="code-btn" disabled="{{f}}" bindtap="{{g}}">{{e}}</button></view><view class="code-tip">开发测试可直接使用万能验证码 666666</view></view><button class="primary-btn login-btn" loading="{{h}}" bindtap="{{i}}"> 登录 / 注册 </button><view class="agreement-wrapper"><label class="agreement-checkbox" bindtap="{{n}}"><checkbox checked="{{j}}" color="#f97316" style="transform:scale(0.7)" catchtap="{{k}}"/><text class="agreement-text"> 我已阅读并同意 <text class="agreement-link" catchtap="{{l}}">《注册协议》</text>与 <text class="agreement-link" catchtap="{{m}}">《隐私协议》</text></text></label></view></view></view>