.results-page {
  padding: 0rpx;
  background-color: transparent;
}

/* Header search row */
.search-header-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 30rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #f1f5f9;
}
.search-input-box {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  border: 1.5rpx solid var(--border-color);
  background: #f8fafc;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  gap: 12rpx;
}
.search-glass-icon {
  font-size: 26rpx;
  color: var(--text-weak);
}
.header-search-input {
  width: 100%;
  height: 100%;
  font-size: 26rpx;
  color: var(--text-main);
}
.search-confirm-btn {
  min-height: 80rpx !important;
  font-size: 26rpx !important;
  padding: 0 36rpx !important;
  border-radius: 40rpx !important;
  background: var(--primary-gradient) !important;
  color: #ffffff !important;
  box-shadow: 0 4rpx 10rpx rgba(249, 115, 22, 0.15) !important;
}

/* Route Details filter title bar */
.route-details-banner {
  padding: 20rpx 32rpx;
  background: var(--primary-light);
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid rgba(249, 115, 22, 0.1);
}
.route-text-line {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.route-point {
  font-size: 26rpx;
  font-weight: 800;
  color: var(--primary-color);
}
.route-connector-arrow {
  font-size: 24rpx;
  color: var(--primary-color);
  font-weight: 800;
}

/* Sub-filter pills */
.sub-filter-pills-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 30rpx 12rpx;
}
.sub-filter-pill {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-muted);
  background: #ffffff;
  padding: 10rpx 30rpx;
  border-radius: 30rpx;
  border: 1.5rpx solid var(--border-color);
  transition: all 0.2s ease;
  cursor: pointer;
}
.sub-filter-pill.active {
  color: var(--primary-color);
  background: var(--primary-light);
  border-color: var(--primary-color);
  box-shadow: 0 2rpx 8rpx rgba(249, 115, 22, 0.05);
}

/* Counts */
.carrier-count-summary {
  font-size: 22rpx;
  color: var(--text-weak);
  padding: 12rpx 32rpx;
  font-weight: 600;
}

/* Empty state styling */
.empty-results-v2 {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}
.empty-visual {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  margin-bottom: 24rpx;
  background: #f1f5f9;
  color: var(--text-weak);
  font-size: 54rpx;
}
.empty-title {
  font-size: 28rpx;
  font-weight: 800;
  color: var(--text-weak);
  margin-bottom: 50rpx;
}
.empty-action-card {
  width: 100%;
  max-width: 600rpx;
  background: #ffffff;
  border-radius: var(--radius-lg);
  padding: 40rpx;
  box-shadow: var(--shadow-md);
  border: 1rpx solid var(--border-color);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}
.empty-quick-btn {
  width: 100%;
  height: 88rpx;
  background: var(--primary-gradient);
  font-size: 28rpx;
  font-weight: 800;
  box-shadow: 0 6rpx 16rpx rgba(249, 115, 22, 0.15);
}
.empty-action-desc {
  font-size: 22rpx;
  color: var(--text-weak);
}

/* Premium V2 Carrier Card */
.carrier-card-v2 {
  padding: 0rpx;
  overflow: hidden;
  margin: 0 24rpx 28rpx;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  border: 1rpx solid rgba(226, 232, 240, 0.7);
}
.carrier-card-header {
  padding: 30rpx 32rpx 20rpx;
  border-bottom: 1rpx solid #f1f5f9;
  background: #ffffff;
}
.carrier-title-block {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.carrier-name-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.carrier-company-name {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text-main);
}
.rating-and-tags {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}
.mini-tag {
  min-height: 36rpx !important;
  font-size: 18rpx !important;
  padding: 0 10rpx !important;
  border-radius: 6rpx !important;
  line-height: 1.5;
}

/* Services rows block */
.carrier-services-block {
  padding: 20rpx 32rpx;
  background: #f8fafc;
  border-bottom: 1rpx solid #f1f5f9;
}
.service-price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 26rpx;
}
.service-name-label {
  color: var(--text-muted);
  font-weight: 700;
}
.service-meta-right {
  display: flex;
  align-items: center;
  gap: 18rpx;
}
.service-time-lbl {
  font-size: 22rpx;
  color: var(--text-weak);
  font-weight: 500;
}
.service-price-val {
  font-size: 26rpx;
  font-weight: 800;
  color: var(--text-weak);
}
.service-price-val.highlight {
  color: var(--primary-color);
  font-size: 30rpx;
}

/* Actions block - split grid layout */
.carrier-actions-block {
  display: grid;
  grid-template-columns: 1fr 1.15fr;
  gap: 20rpx;
  padding: 24rpx 32rpx;
  background: #ffffff;
}
.contact-action-btn {
  min-height: 80rpx !important;
  font-size: 26rpx !important;
  border-radius: 40rpx !important;
  border: 1.5rpx solid var(--primary-color) !important;
  color: var(--primary-color) !important;
  background: #ffffff !important;
  box-shadow: none !important;
}
.contact-action-btn:active {
  background: var(--primary-light) !important;
}
.create-order-action-btn {
  min-height: 80rpx !important;
  font-size: 26rpx !important;
  border-radius: 40rpx !important;
  background: var(--primary-gradient) !important;
  color: #ffffff !important;
  box-shadow: 0 6rpx 16rpx rgba(249, 115, 22, 0.2) !important;
}
.create-order-action-btn:active {
  box-shadow: 0 2rpx 8rpx rgba(249, 115, 22, 0.1) !important;
}

/* Loading box styling */
.loading-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 140rpx 40rpx;
  color: var(--text-weak);
  gap: 24rpx;
}
.loading-spinner {
  font-size: 54rpx;
  animation: bounce 1.2s infinite ease-in-out;
}
@keyframes bounce {
0%,
  100% {
    transform: translateY(0);
}
50% {
    transform: translateY(-16rpx);
}
}
.loading-text {
  font-size: 24rpx;
  font-weight: 600;
}