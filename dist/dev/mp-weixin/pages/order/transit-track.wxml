<view wx:if="{{a}}" class="transit-track-page"><view class="map-panel"><map class="route-map" latitude="{{b}}" longitude="{{c}}" scale="{{d}}" markers="{{e}}" polyline="{{f}}" include-points="{{g}}"/><view class="map-summary"><view class="summary-main"><text class="summary-title">{{h}}</text><text class="summary-sub">{{i}} → {{j}}</text></view><view class="summary-status">运输中</view></view><view class="transit-sheet"><view class="sheet-header"><view class="sheet-header-main"><view class="sheet-title-row"><text class="sheet-title">位置上报</text><text class="sheet-count">{{k}}条</text></view><text class="sheet-route">{{l}} <text wx:if="{{m}}"> · {{n}}</text></text></view><button wx:if="{{o}}" class="sheet-toggle-btn" bindtap="{{p}}"> 查看全部 </button></view><view class="legend-row compact-legend"><view class="legend-item"><text class="legend-line traveled"></text><text>已走路线</text></view><view class="legend-item"><text class="legend-line remaining"></text><text>未走路线</text></view></view><view wx:if="{{q}}" class="route-error">{{r}}</view><view wx:if="{{s}}" class="latest-location-preview" bindtap="{{z}}"><view class="location-index latest">1</view><view class="location-main compact"><view class="location-top"><text class="location-title">{{t}}</text><text class="location-time">{{v}}</text></view><text class="location-address single-line">{{w}}</text><text wx:if="{{x}}" class="location-remark single-line">备注：{{y}}</text></view><text class="preview-arrow">›</text></view><view wx:else class="empty-location"> 承运商还未上报在途位置，路线将按起始地到目的地展示。 </view></view><view wx:if="{{A}}" class="records-panel"><view class="records-panel-head"><view><view class="sheet-title-row"><text class="sheet-title">全部上报记录</text><text class="sheet-count">{{B}}条</text></view><text class="sheet-route">按最新上报时间排序</text></view><button class="sheet-toggle-btn" bindtap="{{C}}">收起</button></view><scroll-view class="records-scroll" scroll-y show-scrollbar><view class="locations-list records-list"><view wx:for="{{D}}" wx:for-item="loc" wx:key="h" class="location-row"><view class="{{['location-index', loc.b && 'latest']}}">{{loc.a}}</view><view class="location-main"><view class="location-top"><text class="location-title">{{loc.c}}</text><text class="location-time">{{loc.d}}</text></view><text class="location-address">{{loc.e}}</text><text wx:if="{{loc.f}}" class="location-remark">备注：{{loc.g}}</text></view></view></view></scroll-view></view></view></view><view wx:else class="page transit-track-page loading-page"><view class="section empty-location">正在加载在途位置...</view></view>