<view class="page contract-page"><view class="section contract-header-card"><view class="contract-doc-header"><view class="doc-meta"><view class="doc-title-main">汽车托运模拟合同</view><view class="doc-no-sub">合同编号：{{a}}</view></view></view></view><view class="section contract-paper"><view class="paper-watermark">CONFIDENTIAL</view><text class="contract-text">{{b}}</text><view class="paper-signature-row"><view class="signature-box"><text class="sig-label">甲方（车商）确认</text><view wx:if="{{c}}" class="stamp-seal approved"><view class="stamp-inner">已确认</view><view class="stamp-date">{{d}}</view></view><view wx:else class="stamp-placeholder">等待确认</view></view><view class="signature-box"><text class="sig-label">乙方（承运商）确认</text><view wx:if="{{e}}" class="stamp-seal approved"><view class="stamp-inner">已确认</view><view class="stamp-date">{{f}}</view></view><view wx:else class="stamp-placeholder">等待确认</view></view></view></view><view class="section"><view class="section-title">合同确认进度</view><view class="info-row"><text class="sig-flow-label">车商（您）确认状态</text><text class="{{['status-tag', h]}}">{{g}}</text></view><view class="info-row"><text class="sig-flow-label">承运商确认状态</text><text class="{{['status-tag', j]}}">{{i}}</text></view></view><view class="fixed-footer"><button wx:if="{{k}}" class="primary-btn confirm-contract-btn" loading="{{l}}" bindtap="{{m}}"> 确认模拟合同 </button><button wx:else class="plain-btn confirm-contract-btn" bindtap="{{n}}">返回订单详情</button></view></view>