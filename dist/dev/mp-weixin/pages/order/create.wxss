.create-order-page {
  padding: 24rpx 24rpx calc(160rpx + env(safe-area-inset-bottom));
  background-color: transparent;
}

/* Steps progress indicator bar */
.steps-progress-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 40rpx;
  background: #ffffff;
  border-radius: var(--radius-lg);
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(229, 231, 235, 0.5);
}
.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.step-num {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #f3f4f6;
  color: #9ca3af;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: bold;
}
.step-lbl {
  font-size: 22rpx;
  color: #9ca3af;
  font-weight: 600;
}
.step-item.active .step-num {
  background: var(--primary-color);
  color: #ffffff;
}
.step-item.active .step-lbl {
  color: var(--primary-color);
}
.step-line {
  flex: 1;
  height: 2rpx;
  background: #e5e7eb;
  margin: 0 20rpx;
  margin-top: -30rpx;
}

/* Form section card overrides */
.form-section-card {
  margin-bottom: 24rpx;
  padding: 32rpx;
}
.clickable-row-card:active {
  background-color: #f9fafb;
}
.card-row-content {
  margin-top: 10rpx;
}
.card-display-value {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.sub-meta-phone {
  font-size: 22rpx;
  color: #9ca3af;
  font-family: monospace;
}
.row-arrow {
  font-size: 24rpx;
  color: #d1d5db;
}
.row-arrow.space-left {
  margin-left: 12rpx;
}
.card-desc-warn {
  font-size: 20rpx;
  color: #9ca3af;
  margin-top: 16rpx;
}

/* Carrier info details */
.carrier-info-display-row {
  display: flex;
  gap: 20rpx;
  align-items: flex-start;
  margin-top: 10rpx;
}
.carrier-meta-v2 {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.carrier-instructions-sub {
  font-size: 20rpx;
  color: #9ca3af;
  line-height: 1.4;
}

/* Address details route blocks */
.route-address-block {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.border-bottom {
  border-bottom: 1rpx solid #f3f4f6;
  padding-bottom: 24rpx;
}
.pt-4 {
  padding-top: 24rpx;
}
.route-city-text {
  font-size: 34rpx;
  color: #111827;
}
.check-address-row {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.check-pill {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 24rpx;
  color: #9ca3af;
  padding: 10rpx 0;
  transition: all 0.2s ease;
}
.check-pill.active {
  color: var(--primary-color);
  font-weight: bold;
}
.check-bullet {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  border: 4rpx solid #e5e7eb;
}
.check-pill.active .check-bullet {
  border-color: var(--primary-color);
  background: var(--primary-color);
}
.address-input-wrapper {
  border: 1rpx solid #e5e7eb;
  border-radius: var(--radius-md);
  background: #f9fafb;
  padding: 16rpx 24rpx;
}
.address-picker-trigger {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  min-height: 72rpx;
  box-sizing: border-box;
}
.address-picker-trigger:active {
  background: #f3f4f6;
}
.route-address-summary {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.route-address-name {
  color: #111827;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.35;
}
.route-address-detail {
  color: #6b7280;
  font-size: 22rpx;
  line-height: 1.45;
}
.route-address-placeholder {
  flex: 1;
  color: #d1d5db;
  font-size: 26rpx;
}
.address-detail-inline {
  width: 100%;
  font-size: 26rpx;
  color: #111827;
}

/* Contacts row */
.contact-select-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
}
.contact-select-row.clickable:active {
  opacity: 0.7;
}
.contact-lbl-title {
  font-size: 28rpx;
  color: #4b5563;
  font-weight: bold;
}
.contact-person-name {
  font-size: 28rpx;
  color: #111827;
}
.placeholder-val {
  font-size: 26rpx;
  color: #d1d5db;
}

/* Vehicle card summary V2 */
.add-vehicle-link {
  font-size: 24rpx;
  color: var(--primary-color);
  font-weight: bold;
}
.added-vehicles-summary-list {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.added-veh-pill-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #f9fafb;
  border-radius: var(--radius-md);
  padding: 20rpx 24rpx;
  border: 1rpx solid #e5e7eb;
}
.veh-text-meta {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.veh-full-title {
  font-size: 26rpx;
  color: #111827;
}
.veh-details-desc {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 20rpx;
  color: #9ca3af;
}
.veh-cond-badge {
  background: var(--primary-light);
  color: var(--primary-color);
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
  font-weight: bold;
}
.veh-plate-vin {
  color: #4b5563;
}

/* Form row parameters list styling */
.form-row-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 0;
}
.border-none {
  border-bottom: none !important;
}
.form-row-lbl {
  font-size: 28rpx;
  color: #4b5563;
  font-weight: bold;
}
.picker-row-val {
  display: flex;
  align-items: center;
}
.form-row-input-val {
  font-size: 28rpx;
  color: var(--primary-color);
  width: 240rpx;
}
.radio-choices-row {
  display: flex;
  align-items: center;
  background: #f3f4f6;
  border-radius: 30rpx;
  padding: 4rpx;
  width: -moz-fit-content;
  width: fit-content;
}
.radio-choices-row.full-width {
  width: 100%;
}
.radio-choice-btn {
  font-size: 24rpx;
  font-weight: 600;
  color: #9ca3af;
  padding: 10rpx 36rpx;
  border-radius: 26rpx;
  transition: all 0.2s ease;
}
.radio-choice-btn.active {
  background: #ffffff;
  color: var(--primary-color);
  font-weight: bold;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.05);
}
.create-footer-bar {
  z-index: 900;
}
.footer-next-step-btn {
  width: 100%;
  height: 88rpx;
  background: var(--primary-color);
  font-size: 28rpx;
  font-weight: bold;
  box-shadow: 0 6rpx 20rpx rgba(249, 115, 22, 0.2);
}
.footer-next-step-btn:active {
  background: #ea580c;
}

/* Drawer Tip */
.drawer-tip-notice {
  font-size: 22rpx;
  color: #9ca3af;
  background: #f9fafb;
  padding: 16rpx 24rpx;
  border-radius: var(--radius-sm);
  margin-bottom: 24rpx;
}
.drawer-link-action {
  color: var(--primary-color);
  font-weight: bold;
  font-size: 24rpx;
  padding: 16rpx 0;
  text-decoration: underline;
  margin-bottom: 30rpx;
}
.drawer-submit-btn {
  width: 100%;
  height: 88rpx;
  font-size: 28rpx;
  font-weight: bold;
  background: var(--primary-color);
  box-shadow: none;
}

/* Vehicles Drawer List block */
.scrollable-drawer-body {
  max-height: 60vh;
}
.vehicle-editor-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}
.vehicle-editor-card {
  border: 1rpx solid #eef0f3;
  border-radius: 28rpx;
  padding: 0 28rpx;
  background: #ffffff;
  overflow: hidden;
}
.veh-editor-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #f1f2f4;
  padding: 22rpx 0;
}
.veh-index-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #111827;
}
.veh-delete-btn-lbl {
  font-size: 24rpx;
  color: #dc2626;
  font-weight: bold;
  padding: 4rpx 12rpx;
}
.vehicle-form-panel {
  display: flex;
  flex-direction: column;
}
.vehicle-form-row {
  display: flex;
  align-items: center;
  min-height: 96rpx;
  border-bottom: 1rpx solid #f1f2f4;
}
.vehicle-form-row.clickable:active {
  opacity: 0.75;
}
.vehicle-row-label {
  width: 150rpx;
  flex-shrink: 0;
  color: #5f636b;
  font-size: 28rpx;
  font-weight: 700;
}
.vehicle-row-value {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
}
.vehicle-row-value.with-arrow {
  justify-content: space-between;
}
.vehicle-picked-text {
  flex: 1;
  min-width: 0;
  color: #2f3135;
  font-size: 28rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.vehicle-placeholder {
  flex: 1;
  min-width: 0;
  color: #b8bbc2;
  font-size: 27rpx;
  font-weight: 600;
}
.vehicle-row-input {
  flex: 1;
  min-width: 0;
  height: 88rpx;
  color: #2f3135;
  font-size: 27rpx;
}
.vehicle-value-unit {
  flex-shrink: 0;
  color: #2f3135;
  font-size: 28rpx;
  font-weight: 700;
}
.vehicle-condition-row {
  min-height: 100rpx;
}
.vehicle-condition-options {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 44rpx;
}
.vehicle-condition-option {
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: #2f3135;
  font-size: 28rpx;
  font-weight: 700;
}
.vehicle-radio {
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  border: 3rpx solid #c4c7cc;
  background: #ffffff;
  box-sizing: border-box;
}
.vehicle-radio.active {
  border: 10rpx solid #ff4d5d;
}
.vehicle-picker-body {
  padding-top: 0;
}
.vehicle-picker-tabs {
  display: flex;
  gap: 12rpx;
  padding-bottom: 18rpx;
}
.vehicle-picker-tab {
  flex: 1;
  height: 60rpx;
  border-radius: 30rpx;
  background: #f3f4f6;
  color: #8b9099;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 60rpx;
  text-align: center;
}
.vehicle-picker-tab.active {
  background: var(--primary-light);
  color: var(--primary-color);
}
.vehicle-picker-current {
  margin-bottom: 16rpx;
  padding: 14rpx 18rpx;
  border-radius: 12rpx;
  background: #f9fafb;
  color: #4b5563;
  font-size: 24rpx;
  line-height: 1.4;
}
.vehicle-picker-list {
  height: 55vh;
  border-top: 1rpx solid #f1f2f4;
}
.vehicle-picker-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 88rpx;
  border-bottom: 1rpx solid #f1f2f4;
  color: #111827;
  font-size: 28rpx;
  font-weight: 700;
}
.vehicle-picker-empty {
  padding: 80rpx 0;
  color: #9ca3af;
  font-size: 26rpx;
  text-align: center;
}
.drawer-add-veh-action {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  border: 1rpx dashed #d1d5db;
  border-radius: var(--radius-md);
  color: var(--primary-color);
  font-size: 26rpx;
  font-weight: bold;
  margin: 24rpx 0 36rpx;
}

/* Value Added Service Popup V2 style */
.pay-service-card {
  border: 1rpx solid #e5e7eb;
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-bottom: 20rpx;
  background: #ffffff;
  transition: all 0.2s ease;
}
.pay-service-card.active {
  border-color: var(--primary-color);
  background: var(--primary-light);
}
.service-card-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.service-title-check {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.custom-check-box {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #d1d5db;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: transparent;
  font-weight: bold;
}
.custom-check-box.checked {
  background: var(--primary-color);
  border-color: var(--primary-color);
  color: #ffffff;
}
.service-name-title {
  font-size: 28rpx;
  color: #111827;
}
.service-price-meta {
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.service-price-yuan {
  font-size: 28rpx;
  color: var(--primary-color);
}
.service-price-original {
  font-size: 20rpx;
  color: #9ca3af;
  text-decoration: line-through;
}
.service-card-details {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx dashed #e5e7eb;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.service-detail-bullet {
  font-size: 22rpx;
  color: #4b5563;
  line-height: 1.4;
}

/* Payment Methods */
.payment-methods-block {
  margin-top: 30rpx;
  border-top: 1rpx solid #e5e7eb;
  padding-top: 24rpx;
}
.payment-section-title {
  font-size: 26rpx;
  color: #111827;
  margin-bottom: 16rpx;
}
.pay-method-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}
.pay-method-item.disabled {
  opacity: 0.5;
}
.method-left-info {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}
.method-lbl {
  font-size: 26rpx;
  color: #111827;
  font-weight: 600;
}
.method-select-circle {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #d1d5db;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}
.method-select-circle.checked {
  border-color: var(--primary-color);
}
.method-select-circle.disabled {
  background: #f3f4f6;
  border-color: #e5e7eb;
}
.circle-inner {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: var(--primary-color);
}

/* Agreement Consent */
.payment-agreement-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 30rpx;
  margin-bottom: 30rpx;
}
.agreement-lbl {
  font-size: 22rpx;
  color: #4b5563;
}

/* Final Action Row inside Popup Drawer */
.drawer-action-pay-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 1rpx solid #e5e7eb;
  padding-top: 24rpx;
}
.pay-amount-total-block {
  display: flex;
  align-items: baseline;
}
.total-symbol {
  font-size: 26rpx;
  color: var(--primary-color);
  font-weight: bold;
}
.total-val {
  font-size: 40rpx;
  color: var(--primary-color);
  margin-right: 8rpx;
}
.total-details-lbl {
  font-size: 20rpx;
  color: var(--primary-color);
}
.pay-submit-btn {
  min-height: 80rpx !important;
  font-size: 26rpx !important;
  padding: 0 36rpx !important;
  border-radius: var(--radius-md) !important;
  background: var(--primary-color) !important;
  box-shadow: none !important;
  margin-left: 12rpx;
}
.pay-submit-btn:active {
  background: #ea580c !important;
}