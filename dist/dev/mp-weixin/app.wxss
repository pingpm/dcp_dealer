page {
  min-height: 100%;
  background: #f5f7fa;
  color: #111827;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Arial, sans-serif;
}
button {
  border-radius: 8rpx;
}
button::after {
  border: 0;
}

/* Global Design System - Dealer App Orange Theme */
page {
  --primary-color: #f97316;
  --primary-light: #fff5eb;
  --primary-gradient: #f97316;
  --primary-gradient-start: #ff9f43;
  --primary-gradient-end: #f97316;
  --primary-glow: rgba(249, 115, 22, 0.15);
  --success-color: #10b981;
  --success-light: #ecfdf5;
  --warning-color: #f59e0b;
  --warning-light: #fffbeb;
  --danger-color: #ef4444;
  --danger-light: #fef2f2;
  --info-color: #3b82f6;
  --info-light: #eff6ff;
  --text-main: #0f172a;
  --text-muted: #475569;
  --text-weak: #94a3b8;
  --border-color: #e2e8f0;
  --bg-color: #f8fafc;
  --radius-lg: 24rpx;
  --radius-md: 16rpx;
  --radius-sm: 10rpx;
  --shadow-sm: 0 2rpx 8rpx rgba(15, 23, 42, 0.04);
  --shadow-md: 0 8rpx 24rpx rgba(15, 23, 42, 0.06);
  --shadow-lg: 0 16rpx 40rpx rgba(15, 23, 42, 0.08);
}

page,
body,
#app {
  min-height: 100%;
  background: var(--bg-color);
  color: var(--text-main);
  font-family: 'Outfit', 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue', Arial, sans-serif;
  -webkit-font-smoothing: antialiased;
}

page {
  font-size: 28rpx;
}

view,
text,
scroll-view,
input,
textarea,
button {
  box-sizing: border-box;
}

.page {
  min-height: 100vh;
  padding: 28rpx;
  background: linear-gradient(180deg, #fffcf9 0%, #f8fafc 400rpx);
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

/* Card Section */
.section {
  margin-bottom: 28rpx;
  padding: 34rpx;
  border-radius: var(--radius-lg);
  background: #ffffff;
  border: 1rpx solid rgba(226, 232, 240, 0.8);
  box-shadow: var(--shadow-sm);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.section:active {
  transform: translateY(1rpx);
  box-shadow: 0 2rpx 4rpx rgba(15, 23, 42, 0.02);
}

.section-title {
  position: relative;
  margin-bottom: 28rpx;
  padding-left: 24rpx;
  color: var(--text-main);
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.4;
  letter-spacing: 0.5rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 8rpx;
  bottom: 8rpx;
  width: 8rpx;
  border-radius: 4rpx;
  background: linear-gradient(180deg, var(--primary-gradient-start), var(--primary-gradient-end));
}

.subtle {
  color: var(--text-muted);
  font-size: 24rpx;
  line-height: 1.6;
}

/* Form Controls */
.field {
  margin-bottom: 28rpx;
}

.field:last-child {
  margin-bottom: 0;
}

.label {
  display: block;
  margin-bottom: 14rpx;
  color: var(--text-muted);
  font-size: 26rpx;
  font-weight: 700;
}

.input,
.textarea,
.picker-display {
  width: 100%;
  min-height: 92rpx;
  padding: 0 32rpx;
  border: 1.5rpx solid var(--border-color);
  border-radius: var(--radius-md);
  background: #f8fafc;
  color: var(--text-main);
  font-size: 28rpx;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: inset 0 2rpx 4rpx rgba(0, 0, 0, 0.01);
}

.textarea {
  min-height: 190rpx;
  padding: 24rpx 32rpx;
  line-height: 1.6;
}

.picker-display {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-display::after {
  content: '▼';
  font-size: 18rpx;
  color: var(--text-weak);
  margin-left: 10rpx;
  transition: transform 0.2s ease;
}

.input:focus,
.textarea:focus {
  border-color: var(--primary-color);
  background: #ffffff;
  box-shadow: 0 0 0 6rpx var(--primary-glow);
  outline: none;
}

/* Layout helpers */
.row {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.row-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.grid-two {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

/* Custom Checkbox Row */
.check-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx 28rpx;
  border-radius: var(--radius-md);
  background: #f8fafc;
  border: 1.5rpx solid var(--border-color);
  color: var(--text-muted);
  font-size: 26rpx;
  transition: all 0.25s ease;
}

.check-row.checked {
  background: var(--primary-light);
  border-color: #fdbb74;
  color: var(--primary-color);
  font-weight: 700;
  box-shadow: 0 2rpx 8rpx rgba(249, 115, 22, 0.05);
}

/* Buttons */
.primary-btn,
.secondary-btn,
.danger-btn,
.plain-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 92rpx;
  margin: 0;
  padding: 0 36rpx;
  border-radius: 46rpx; /* Pill styled buttons for modern app feel */
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1;
  transition: all 0.25s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  border: none;
  cursor: pointer;
}

.primary-btn {
  background: linear-gradient(135deg, var(--primary-gradient-start), var(--primary-gradient-end));
  color: #ffffff;
  box-shadow: 0 10rpx 24rpx rgba(249, 115, 22, 0.25);
}

.primary-btn:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 12rpx rgba(249, 115, 22, 0.15);
}

.secondary-btn {
  background: var(--primary-light);
  color: #c2410c;
  border: 1.5rpx solid #fed7aa;
}

.secondary-btn:active {
  background: #ffedd5;
  transform: scale(0.97);
}

.danger-btn {
  background: linear-gradient(135deg, #f87171, var(--danger-color));
  color: #ffffff;
  box-shadow: 0 10rpx 24rpx rgba(239, 68, 68, 0.2);
}

.danger-btn:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 12rpx rgba(239, 68, 68, 0.12);
}

.plain-btn {
  background: #ffffff;
  color: var(--text-muted);
  border: 1.5rpx solid var(--border-color);
  box-shadow: var(--shadow-sm);
}

.plain-btn:active {
  background: #f8fafc;
  transform: scale(0.97);
}

/* Status Badges */
.status-tag {
  display: inline-flex;
  align-items: center;
  min-height: 48rpx;
  padding: 0 20rpx;
  border-radius: 30rpx;
  background: #f1f5f9;
  color: #475569;
  font-size: 22rpx;
  font-weight: 700;
  border: 1rpx solid rgba(226, 232, 240, 0.6);
}

/* Shared logged-out prompt used by tab pages */
.guest-prompt-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx 28rpx;
  border-radius: var(--radius-lg);
  border: 1rpx solid #fde1c3;
  background: linear-gradient(135deg, #fff7ed 0%, #fffbeb 100%);
  box-shadow: var(--shadow-sm);
  margin-bottom: 28rpx;
}

@media screen and (max-width: 360px) {
  .guest-prompt-card {
    gap: 14rpx;
    padding: 18rpx 22rpx;
  }

  .guest-prompt-action {
    min-width: 150rpx;
    padding: 0 22rpx !important;
  }
}

.guest-prompt-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 46rpx;
  height: 46rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: linear-gradient(135deg, var(--primary-gradient-start), var(--primary-gradient-end));
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1;
  box-shadow: 0 4rpx 10rpx rgba(249, 115, 22, 0.2);
}

.guest-prompt-main {
  flex: 1;
  min-width: 0;
}

.guest-prompt-title {
  color: #c2410c;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1.35;
}

.guest-prompt-desc {
  margin-top: 4rpx;
  color: #ea580c;
  font-size: 22rpx;
  line-height: 1.45;
}

.guest-prompt-action {
  min-width: 140rpx;
  min-height: 60rpx !important;
  padding: 0 24rpx !important;
  border-radius: 30rpx !important;
  background: linear-gradient(135deg, var(--primary-gradient-start), var(--primary-gradient-end)) !important;
  color: #ffffff !important;
  box-shadow: 0 4rpx 10rpx rgba(249, 115, 22, 0.15) !important;
  font-size: 23rpx !important;
  font-weight: 800 !important;
}

.guest-prompt-arrow {
  color: #f97316;
  font-size: 30rpx;
  font-weight: 800;
  padding-left: 8rpx;
}

.status-success {
  background: var(--success-light) !important;
  color: var(--success-color) !important;
  border-color: #a7f3d0 !important;
}

.status-warning {
  background: var(--warning-light) !important;
  color: var(--warning-color) !important;
  border-color: #fde68a !important;
}

.status-danger {
  background: var(--danger-light) !important;
  color: var(--danger-color) !important;
  border-color: #fecaca !important;
}

.status-info {
  background: var(--info-light) !important;
  color: var(--info-color) !important;
  border-color: #bfdbfe !important;
}

/* Empty State */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 130rpx 40rpx;
  color: var(--text-weak);
  text-align: center;
}

.empty::before {
  content: '📁';
  font-size: 88rpx;
  margin-bottom: 24rpx;
  opacity: 0.65;
}

/* Sticky Footer */
.fixed-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(226, 232, 240, 0.8);
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  box-shadow: 0 -4rpx 24rpx rgba(15, 23, 42, 0.04);
}

/* Modern Image Upload Grid */
.upload-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 22rpx;
  margin-top: 18rpx;
}

.upload-card {
  position: relative;
  aspect-ratio: 1;
  background: #f8fafc;
  border: 2rpx dashed var(--border-color);
  border-radius: var(--radius-md);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: var(--text-weak);
  transition: all 0.2s ease;
}

.upload-card:active {
  background: #f1f5f9;
  border-color: var(--primary-color);
}

.upload-card-icon {
  font-size: 52rpx;
  margin-bottom: 8rpx;
  color: var(--text-weak);
}

.upload-card-text {
  font-size: 22rpx;
}

.upload-preview {
  position: relative;
  aspect-ratio: 1;
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.upload-img {
  width: 100%;
  height: 100%;
}

.upload-delete-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  z-index: 10;
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  background: rgba(15, 23, 42, 0.7);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  backdrop-filter: blur(4px);
}

@media (max-width: 360px) {
  .grid-two {
    grid-template-columns: 1fr;
  }
}

/* Helper Utilities */
.font-bold {
  font-weight: 800;
}
.text-right {
  text-align: right;
}
.flex-1 {
  flex: 1;
}
.flex-row {
  display: flex;
  flex-direction: row;
}
.align-center {
  align-items: center;
}
.justify-between {
  justify-content: space-between;
}

/* Custom Bottom Drawer/Popup */
.drawer-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(15, 23, 42, 0.5);
  z-index: 999;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
  backdrop-filter: blur(4px);
}
.drawer-mask.show {
  opacity: 1;
  pointer-events: auto;
}
.drawer-content {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #ffffff;
  border-radius: 36rpx 36rpx 0 0;
  z-index: 1000;
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.15, 1, 0.3, 1);
  padding: 40rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  max-height: 85vh;
  display: flex;
  flex-direction: column;
  box-shadow: 0 -12rpx 36rpx rgba(15, 23, 42, 0.08);
}
.drawer-content.show {
  transform: translateY(0);
}
.drawer-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 34rpx;
  border-bottom: 1rpx solid #f1f5f9;
  padding-bottom: 24rpx;
}
.drawer-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #0f172a;
}
.drawer-close {
  font-size: 38rpx;
  color: #94a3b8;
  padding: 10rpx;
  line-height: 1;
}
.drawer-body {
  flex: 1;
  overflow-y: auto;
}

/* --- Premium Footer Links for Tertiary Actions --- */
.footer-links-row {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 20rpx;
  margin-top: 18rpx;
  width: 100%;
}

.footer-link-text {
  font-size: 24rpx;
  color: var(--text-muted);
  cursor: pointer;
  padding: 8rpx 16rpx;
  font-weight: 500;
  transition: color 0.2s ease;
}

.footer-link-text:active {
  color: var(--primary-color);
}

.footer-link-text.danger {
  color: #94a3b8; /* Give Cancel link a muted gray text style to reduce prominence */
}

.footer-link-text.danger:active {
  color: var(--danger-color);
}

.footer-link-separator {
  color: var(--border-color);
  font-size: 20rpx;
}

.footer-buttons-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  width: 100%;
}

.footer-buttons-row .primary-btn {
  flex: 1.4;
}

.footer-buttons-row .secondary-btn {
  flex: 1;
}
