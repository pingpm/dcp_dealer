<view wx:if="{{a}}" class="address-picker-layer"><view class="address-picker-mask" bindtap="{{b}}"></view><view class="address-picker-panel"><view class="address-picker-header"><view><view class="address-picker-title">{{c}}</view><view class="address-picker-city">{{d}} {{e}}</view></view><view class="address-picker-close" bindtap="{{f}}">×</view></view><view class="address-search-row"><view class="address-search-box"><input class="address-search-input" confirm-type="search" placeholder="{{g}}" placeholder-style="color:#9ca3af" bindinput="{{h}}" bindconfirm="{{i}}" value="{{j}}"/><scroll-view wx:if="{{k}}" scroll-y class="address-suggestion-list"><view wx:for="{{l}}" wx:for-item="item" wx:key="c" class="address-suggestion-item" catchtap="{{item.d}}" catchtap="{{item.e}}"><view class="address-result-name">{{item.a}}</view><view class="address-result-desc">{{item.b}}</view></view></scroll-view></view><button class="address-search-btn" loading="{{m}}" bindtap="{{n}}">搜索</button></view><view wx:if="{{o}}" class="manual-address-box"><view class="manual-address-label">未搜索到地址时可手动填写</view><input class="manual-address-input" placeholder="请输入经营场地详细地址" placeholder-style="color:#9ca3af" value="{{p}}" bindinput="{{q}}"/></view><map class="address-map" latitude="{{r}}" longitude="{{s}}" scale="{{t}}" markers="{{v}}" show-location="{{false}}" bindtap="{{w}}"/><view class="address-picker-actions"><button class="secondary-btn address-action-btn" bindtap="{{x}}">取消</button><button class="primary-btn address-action-btn" bindtap="{{y}}">确认地址</button></view></view></view>