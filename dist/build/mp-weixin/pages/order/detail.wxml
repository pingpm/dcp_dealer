text class="detail-value price-highlight">{{at}}</text></view></view><button wx:if="{{av}}" class="plain-btn w-full" style="margin-top:20rpx" bindtap="{{aw}}"> 查看赔付详情 </button></view><view class="section detail-section-card"><view class="section-title">订单追踪节点</view><view class="timeline-container"><view wx:for="{{ax}}" wx:for-item="log" wx:key="g" class="{{['timeline-item', log.h && 'latest']}}"><view class="timeline-line-wrap"><view class="{{['timeline-dot', log.a]}}"></view><view wx:if="{{log.b}}" class="timeline-trail-line"></view></view><view class="timeline-content"><text class="timeline-action">{{log.c}}</text><text wx:if="{{log.d}}" class="timeline-remark">{{log.e}}</text><text class="timeline-time">{{log.f}}</text></view></view><view wx:if="{{ay}}" class="subtle-empty-logs">暂无订单流程轨迹</view></view></view><view class="fixed-footer detail-footer-actions"><view wx:if="{{az}}" class="footer-alert-notice-text"> 承运商长时间未确认，您可以主动进行联系 </view><view class="actions-wrapper"><view wx:if="{{aA}}" class="footer-buttons-row"><button wx:if="{{aB}}" class="primary-btn flex-btn" bindtap="{{aC}}"> 修改订单信息 </button><button wx:if="{{aD}}" class="primary-btn flex-btn" bindtap="{{aE}}"> 联系承运商 </button><button wx:if="{{aF}}" class="primary-btn flex-btn" bindtap="{{aG}}"> 继续支付担保费 </button><button wx:if="{{aH}}" class="primary-btn flex-btn" bindtap="{{aI}}"> 确认模拟合同 </button><button wx:if="{{aJ}}" class="secondary-btn flex-btn" bindtap="{{aK}}"> 查看在途位置 </button><button wx:if="{{aL}}" class="primary-btn flex-btn" bindtap="{{aM}}"> 确认已收车 </button><view class="more-text-btn" bindtap="{{aN}}">更多</view></view><view wx:else class="footer-buttons-row"><button class="plain-btn flex-btn" bindtap="{{aO}}">协商历史</button></view></view></view></view>