<view class="page order-detail-page"><view class="{{['order-status-summary-card', k]}}"><image class="order-status-summary-icon" src="{{a}}" mode="aspectFit"/><view class="order-status-summary-main"><view class="order-status-summary-head"><text class="order-status-summary-title">{{b}}</text><text wx:if="{{c}}" class="order-status-summary-action" catchtap="{{e}}">{{d}}</text></view><text class="order-status-summary-desc">{{f}}</text><text wx:if="{{g}}" class="order-status-summary-tip">{{h}}</text><text wx:if="{{i}}" class="order-status-summary-no">订单号：{{j}}</text></view></view><view wx:if="{{l}}" class="latest-location-card" bindtap="{{p}}"><view class="latest-location-main"><view class="latest-location-status-row"><image class="latest-location-status-icon" src="{{m}}" mode="aspectFit"/><text class="latest-location-status-title">{{n}}</text></view><view class="latest-location-info-row"><text class="latest-location-label">最新位置</text><view class="latest-location-value-wrap"><text class="latest-location-value">{{o}}</text><text class="latest-location-arrow">›</text></view></view></view></view><view wx:if="{{q}}" class="section invitation-share-card"><view class="invite-title-row font-bold">承运商邀请</view><view class="invite-desc-v2"> 该承运商手机号未注册入驻。填写订单后，您可复制链接或直接通过微信分享，邀请其入驻并确认订单： </view><view class="share-link-input-row"><text class="share-link-lbl">邀请链接：</text><input class="share-link-input font-mono" value="{{r}}" readonly disabled/></view><view class="share-actions-row"><button class="primary-btn share-action-btn-small" bindtap="{{s}}"> 复制邀请链接 </button></view></view><view class="section detail-section-card"><view class="carrier-product-head route-card-head"><view class="carrier-product-name"><image class="carrier-product-icon" src="{{t}}" mode="aspectFit"/><text class="carrier-product-title">{{v}}</text></view><view class="carrier-phone-action" catchtap="{{w}}"><text class="phone-action-icon">☎</text><text>电话联系</text></view></view><view class="carrier-product-divider"></view><view class="detail-route-flow"><view class="flow-node"><text class="flow-city">{{x}}</text><text class="flow-role-lbl">发车地</text></view><view class="flow-connector"><view class="flow-bar"></view><text class="flow-mode-tag">{{y}}</text></view><view class="flow-node text-right"><text class="flow-city">{{z}}</text><text class="flow-role-lbl">收车地</text></view></view><view class="detail-grid-info"><view class="detail-row"><text class="detail-label">约定托运运费</text><text class="detail-value price-highlight">{{A}}</text></view><view class="detail-row"><text class="detail-label">约定最迟送达</text><text class="detail-value">{{B}}</text></view><view class="detail-row"><text class="detail-label">开具发票</text><text class="detail-value">{{C}}</text></view></view></view><view class="section detail-section-card"><view class="section-title">提送车服务</view><view class="service-info-list"><view wx:if="{{D}}" class="service-info-item"><view class="service-info-head"><text class="service-info-title">提车服务</text><text class="{{['status-tag', 'mini-tag-v2', F]}}">{{E}}</text></view><view wx:if="{{G}}" class="detail-row service-address-row"><text class="detail-label">提车位置</text><text class="detail-value service-address">{{H}}</text></view></view><view wx:if="{{I}}" class="service-info-item"><view class="service-info-head"><text class="service-info-title">送车服务</text><text class="{{['status-tag', 'mini-tag-v2', K]}}">{{J}}</text></view><view wx:if="{{L}}" class="detail-row service-address-row"><text class="detail-label">送车位置</text><text class="detail-value service-address">{{M}}</text></view></view></view></view><view class="section detail-section-card"><view class="section-title">联系人信息</view><view class="detail-grid-info"><view class="detail-row border-bottom-mini"><text class="detail-label">客户主体</text><text class="detail-value">{{N}}</text></view><view class="detail-row border-bottom-mini pt-2"><view class="contact-lbl-block"><text class="bullet-tag orange">●</text><text class="contact-role-name">发车人</text></view><text class="detail-value">{{O}}</text></view><view class="detail-row pt-2"><view class="contact-lbl-block"><text class="bullet-tag blue">●</text><text class="contact-role-name">收车人</text></view><text class="detail-value">{{P}}</text></view></view></view><view class="section detail-section-card"><view class="section-title">承运车辆 ({{Q}}辆)</view><view wx:for="{{R}}" wx:for-item="vehicle" wx:key="g" class="detail-vehicle-item"><view class="vehicle-head"><text class="vehicle-icon">车</text><text class="vehicle-title font-bold">{{vehicle.a}} {{vehicle.b}} {{vehicle.c}}</text></view><view class="vehicle-details"><view class="vehicle-col"><text class="veh-lbl">车架号 (VIN)</text><text class="veh-val font-mono">{{vehicle.d}}</text></view><view class="vehicle-col"><text class="veh-lbl">车牌号</text><text class="veh-val font-mono">{{vehicle.e}}</text></view><view class="vehicle-col text-right"><text class="veh-lbl">车况类型</text><text class="status-tag status-success mini-tag-v2">{{vehicle.f}}</text></view></view></view></view><view wx:if="{{S}}" class="section detail-section-card"><view class="section-title">承运司机信息</view><view wx:if="{{T}}" class="driver-block"><view class="driver-role-title">提车司机</view><view class="detail-grid-info"><view class="detail-row"><text class="detail-label">姓名电话</text><text class="detail-value">{{U}} ({{V}})</text></view><view class="detail-row"><text class="detail-label">车牌/身份证</text><text class="detail-value font-mono">{{W}} / {{X}}</text></view></view></view><view wx:if="{{Y}}" class="driver-block separator"><view class="driver-role-title">交车司机</view><view class="detail-grid-info"><view class="detail-row"><text class="detail-label">姓名电话</text><text class="detail-value">{{Z}} ({{aa}})</text></view><view class="detail-row"><text class="detail-label">车牌/身份证</text><text class="detail-value font-mono">{{ab}} / {{ac}}</text></view></view></view></view><view wx:if="{{ad}}" class="section detail-section-card"><view class="section-title">提车验车记录<