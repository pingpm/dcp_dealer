<view wx:if="{{a}}" class="transit-track-page"><view class="map-panel"><map class="route-map" latitude="{{b}}" longitude="{{c}}" scale="{{d}}" markers="{{e}}" polyline="{{f}}" include-points="{{g}}"/><view class="map-summary"><view class="summary-main"><text class="summary-title">{{h}}</text><text class="summary-sub">{{i}} → {{j}}</text></view><view class="{{['summary-status', l]}}">{{k}}</view></view><view class="{{['transit-sheet', z && 'expanded']}}"><view class="sheet-header"><view class="sheet-header-main"><view class="sheet-title-row"><text class="sheet-title">位置上报</text><text class="sheet-count">{{m}}条</text></view><text class="sheet-route">{{n}} <text wx:if="{{o}}"> · {{p}}</text></text></view><button wx:if="{{q}}" class="sheet-toggle-btn" bindtap="{{s}}">{{r}}</button></view><view class="legend-row compact-legend"><view class="legend-item"><text class="legend-line traveled"></text><text>已走路线</text></view><view class="legend-item"><text class="legend-line remaining"></text><text>未走路线</text></view></view><view wx:if="{{t}}" class="route-error">{{v}}</view><view wx:if="{{w}}" class="{{['records-scroll', y && 'expanded']}}"><view class="locations-list records-list"><view wx:for="{{x}}" wx:for-item="loc" wx:key="h" class="location-row"><view class="{{['location-index', loc.b && 'latest']}}">{{loc.a}}</view><view class="location-main"><view class="location-top"><text class="location-title">{{loc.c}}</text><text class="location-time">{{loc.d}}</text></view><text class="location-address">{{loc.e}}</text><text wx:if="{{loc.f}}" class="location-remark">备注：{{loc.g}}</text></view></view></view></view><view wx:else class="empty-location"> 承运商还未上报在途位置，路线将按起始地到目的地展示。 </view></view></view></view><view wx:else class="page transit-track-page loading-page"><view class="section empty-location">正在加载在途位置...</view><miniapp-login-sheet class="r" u-r="loginSheet" bindsuccess="{{B}}" u-i="3afe98bf-0" bind:__l="__l"/></view>