.cancel-request-page{padding:30rpx}.cancel-warn-card-modern{background:var(--danger-light);border:1rpx solid rgba(239,68,68,.15);border-radius:var(--radius-md);padding:30rpx;margin-bottom:28rpx;box-shadow:0 4rpx 12rpx rgba(239,68,68,.02)}.warn-header-modern{display:flex;align-items:center;gap:12rpx;margin-bottom:20rpx}.warn-icon-modern{flex-shrink:0}.warn-title-modern{font-size:28rpx;font-weight:700;color:var(--danger-color)}.warn-body-modern{display:flex;flex-direction:column;gap:16rpx}.warn-item-modern{display:flex;align-items:flex-start;gap:14rpx}.warn-dot-modern{width:8rpx;height:8rpx;border-radius:50%;background-color:var(--danger-color);margin-top:12rpx;flex-shrink:0}.warn-text-modern{font-size:24rpx;color:#6b7280;line-height:1.5}.highlight-danger{font-weight:700;color:var(--danger-color);margin:0 4rpx}.cancel-textarea{font-size:28rpx;line-height:1.6;border-color:var(--border-color)}.word-counter{text-align:right;font-size:20rpx;color:var(--text-weak);margin-top:10rpx;padding-right:10rpx}.submit-cancel-btn{width:100%}