<view class="page agreement-page"><view class="agreement-header"><view class="agreement-kicker">车商端协议</view><view class="agreement-title">{{a}}</view><view class="agreement-meta"><text>生效日期：{{b}}</text><text wx:if="{{c}}" class="agreement-version">版本：{{d}}</text></view><view class="agreement-summary">{{e}}</view></view><scroll-view class="agreement-scroll" scroll-y><view class="agreement-content"><view wx:if="{{f}}" class="agreement-loading">正在加载协议内容...</view><block wx:else><view wx:for="{{g}}" wx:for-item="section" wx:key="c" class="agreement-section"><view class="section-heading">{{section.a}}</view><view wx:for="{{section.b}}" wx:for-item="paragraph" wx:key="b" class="section-paragraph">{{paragraph.a}}</view></view></block></view></scroll-view></view>